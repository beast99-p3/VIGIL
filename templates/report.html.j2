<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>V.I.G.I.L. Report</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        background: #0f172a;
        color: #e2e8f0;
      }
      .container {
        display: flex;
        min-height: 100vh;
      }
      .sidebar {
        width: 260px;
        padding: 24px;
        background: #111827;
        border-right: 1px solid #1f2937;
      }
      .sidebar h1 {
        font-size: 20px;
        margin: 0 0 12px 0;
      }
      .stat {
        margin: 12px 0;
        padding: 12px;
        background: #0b1220;
        border-radius: 8px;
      }
      .content {
        flex: 1;
        padding: 24px;
      }
      .card {
        background: #111827;
        border: 1px solid #1f2937;
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
        display: flex;
        gap: 16px;
      }
      .thumb {
        width: 200px;
        height: 200px;
        background: #0b1220;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .thumb img {
        max-width: 200px;
        max-height: 200px;
        border-radius: 6px;
      }
      .badges {
        margin-bottom: 8px;
      }
      .badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 12px;
        margin-right: 6px;
        background: #1f2937;
      }
      .severity-critical {
        background: #dc2626;
      }
      .severity-high {
        background: #f97316;
      }
      .severity-medium {
        background: #facc15;
        color: #111827;
      }
      .severity-low {
        background: #22c55e;
      }
      .meta {
        font-size: 12px;
        color: #94a3b8;
      }
      a {
        color: #38bdf8;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="sidebar">
        <h1>V.I.G.I.L. Report</h1>
        <div class="stat">Generated: {{ generated }}</div>
        <div class="stat">Files Scanned: {{ files_scanned }}</div>
        <div class="stat">Threats: {{ threats }}</div>
        <div class="stat">Locations: {{ locations }}</div>
        <div class="stat meta">Root: {{ root }}</div>
      </div>
      <div class="content">
        {% for item in items %}
        <div class="card">
          <div class="thumb">
            {% if item.thumbnail %}
            <img src="{{ item.thumbnail }}" alt="thumbnail" />
            {% else %}
            <span class="meta">No preview</span>
            {% endif %}
          </div>
          <div>
            <div class="badges">
              <span class="badge severity-{{ item.top_severity | lower }}">{{ item.top_severity }}</span>
              {% for finding in item.findings %}
              <span class="badge">{{ finding.module }}{% if finding.summary %}: {{ finding.summary }}{% endif %}</span>
              {% endfor %}
            </div>
            <div class="meta">{{ item.rel_path }}</div>
            <div>
              {% if item.ocr_snippet %}
              <div><strong>OCR:</strong> {{ item.ocr_snippet }}</div>
              {% endif %}
              {% if item.qr_data %}
              <div><strong>QR:</strong> {{ item.qr_data }}</div>
              {% endif %}
              {% if item.yolo_labels %}
              <div><strong>YOLO:</strong> {{ item.yolo_labels | join(", ") }}</div>
              {% endif %}
              {% if item.geoint_link %}
              <div><strong>Location:</strong> <a href="{{ item.geoint_link }}">{{ item.geoint_link }}</a></div>
              {% endif %}
              {% if item.entropy %}
              <div><strong>Entropy:</strong> {{ "%.2f"|format(item.entropy) }}</div>
              {% endif %}
            </div>
            {% if item.findings %}
            <ul>
              {% for finding in item.findings %}
              <li>
                <strong>{{ finding.severity }}</strong> - {{ finding.module }}:
                {{ finding.details or finding.summary }}
              </li>
              {% endfor %}
            </ul>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </body>
</html>
